# ============================================================
# ELYON Group · Variáveis de Ambiente — Camada 02
# Copie este arquivo para .env e preencha os valores reais
# NUNCA comite o .env no repositório — só o .env.example
# ============================================================

# ── Supabase (frontend) ──────────────────────────────────────
# Encontre em: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...sua_anon_key_aqui

# ── Supabase Edge Function (secrets — configure via CLI) ─────
# Execute: supabase secrets set NOME=VALOR
# Não adicione essas variáveis no .env do frontend!

# SUPABASE_URL          → definido automaticamente pela plataforma
# SUPABASE_SERVICE_ROLE_KEY → definido automaticamente pela plataforma

# ── Z-API (WhatsApp automático) ──────────────────────────────
# Crie uma conta em: https://z-api.io
# Encontre as credenciais em: Painel → Sua instância → Credenciais
# Configure via: supabase secrets set ZAPI_INSTANCE_ID=xxx

# ZAPI_INSTANCE_ID=SUA_INSTANCE_ID
# ZAPI_TOKEN=SEU_TOKEN
# ZAPI_CLIENT_TOKEN=SEU_CLIENT_TOKEN   (opcional, para segurança extra)
# ZAPI_RECIPIENT_NUMBER=5511999999999  (número da ELYON que recebe as notificações, com DDI)
